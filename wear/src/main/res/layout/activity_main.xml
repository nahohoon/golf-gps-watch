<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="8dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <!-- 1. K2 GOLF -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.12"
        android:text="@string/brand_title"
        android:textColor="@color/gold"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- 2. HOLE 1 -->
    <TextView
        android:id="@+id/tv_current_hole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/hole_default"
        android:textColor="@color/lime_acc"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 3. 거리 4706m -->
    <LinearLayout
        android:id="@+id/distance_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_horizontal|bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_distance_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:letterSpacing="-0.03"
            android:maxLines="1"
            android:text="@string/distance_num_placeholder"
            android:textColor="@color/dist_white"
            android:textSize="64sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_distance_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginBottom="8dp"
            android:includeFontPadding="false"
            android:text="@string/distance_unit"
            android:textColor="@color/text_bright"
            android:textSize="40sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 4. GPS 수신됨 | ±12m -->
    <TextView
        android:id="@+id/tv_status_line"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="@string/gps_waiting"
        android:textColor="@color/status_success"
        android:textSize="17sp" />

    <!-- 5. 갱신 시간 -->
    <TextView
        android:id="@+id/tv_last_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/last_updated_none"
        android:textColor="@color/text_bright"
        android:textSize="16sp" />

    <!-- 여백: 거리/GPS와 버튼 사이만 확장 (거리 TextView 압축 없음) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 6. 하단 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_prev_hole"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill_button"
            android:minHeight="38dp"
            android:text="@string/prev_hole"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn_refresh"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_refresh_circle"
            android:minHeight="46dp"
            android:minWidth="46dp"
            android:text="@string/refresh"
            android:textColor="@color/dist_white"
            android:textSize="18sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn_next_hole"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill_button"
            android:minHeight="38dp"
            android:text="@string/next_hole"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            app:backgroundTint="@null" />

    </LinearLayout>

</LinearLayout>
